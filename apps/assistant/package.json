{
  "name": "assistant",
  "version": "0.1.0",
  "private": true,
  "description": "Arcanada Assistant — NestJS+Fastify app (Telegram webhook, /health, orchestrator placeholder).",
  "license": "MIT",
  "type": "module",
  "main": "./dist/main.js",
  "scripts": {
    "build": "tsc -p tsconfig.json && node ./scripts/copy-assets.mjs",
    "start": "node dist/main.js",
    "start:dev": "tsx watch src/main.ts",
    "start:prod": "node dist/main.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint . --ext .ts",
    "lint:fix": "eslint . --ext .ts --fix",
    "typecheck": "tsc --noEmit",
    "prisma:generate": "prisma generate",
    "prisma:migrate:dev": "prisma migrate dev",
    "prisma:migrate:deploy": "prisma migrate deploy"
  },
  "dependencies": {
    "@arcanada/core": "workspace:*",
    "@fastify/helmet": "^13.0.1",
    "@fastify/rate-limit": "^11.1.0",
    "@fastify/static": "^9.1.3",
    "@nestjs/bullmq": "^11.0.4",
    "@nestjs/common": "^11.1.27",
    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "^11.1.27",
    "@nestjs/platform-fastify": "^11.1.27",
    "@nestjs/swagger": "^11.4.5",
    "@nestjs/terminus": "^11.0.0",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "bullmq": "^5.79.2",
    "fastify": "^5.10.0",
    "ioredis": "^5.11.1",
    "jose": "^6.2.3",
    "js-yaml": "^5.2.1",
    "json-logic-js": "^2.0.5",
    "nestjs-pino": "^4.6.1",
    "opossum": "^10.0.0",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "pino-pretty": "^13.1.3",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "telegraf": "^4.16.3",
    "unpdf": "^1.6.2",
    "uuid": "^14.0.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@prisma/config": "^7.8.0",
    "@types/js-yaml": "^4.0.9",
    "@types/json-logic-js": "^2.0.8",
    "@types/node": "^26.1.1",
    "@types/opossum": "^8.1.9",
    "@types/supertest": "^7.2.1",
    "@vitest/coverage-v8": "^4.1.10",
    "ioredis-mock": "^8.13.1",
    "msw": "^2.15.0",
    "prisma": "^7.8.0",
    "supertest": "^7.0.0",
    "tsx": "^4.23.1",
    "typescript": "^7.0.2",
    "vitest": "^4.1.10"
  },
  "arcanada": {
    "current_aal": "L3",
    "target_aal": "L4",
    "manifest": "manifest.yaml"
  }
}
