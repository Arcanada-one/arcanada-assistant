# Arcanada Assistant — environment template
# Copy to .env and fill secrets via Vault (NEVER commit .env).
# All variables are validated by Zod schema in apps/assistant/src/config/configuration.ts

# ── App ──────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3800
LOG_LEVEL=info

# ── Database (Postgres on arcana-db, Tailscale-only) ─────────────────
# POSTGRES_PASSWORD MUST be Vault-injected (kv/arcanada-assistant/postgres). Never commit. (SEC-0006)
POSTGRES_PASSWORD=CHANGE_ME
DATABASE_URL=postgresql://assistant_app:CHANGE_ME@arcana-db:5432/assistant?schema=public&sslmode=disable

# ── Redis (arcana-db, Tailscale-only) ────────────────────────────────
# REDIS_PASSWORD MUST be Vault-injected (kv/arcanada-assistant/redis). Never commit. (SEC-0006)
REDIS_PASSWORD=CHANGE_ME
REDIS_URL=redis://:CHANGE_ME@arcana-db:6379/3

# ── Telegram ─────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=CHANGE_ME
TELEGRAM_WEBHOOK_SECRET=CHANGE_ME
TELEGRAM_WEBHOOK_PATH=/webhook/telegram

# ── Auth Arcana (JWKS for service-to-service JWT validation) ─────────
AUTH_ARCANA_BASE_URL=https://auth.arcanada.one
AUTH_ARCANA_JWKS_URL=https://auth.arcanada.one/.well-known/jwks.json
AUTH_ARCANA_JWT_ISSUER=https://auth.arcanada.one
AUTH_ARCANA_JWT_AUDIENCE=arcanada-assistant

# ── Model Connector (LLM proxy, Tailscale) — wired in ARCA-0007 ──────
MODEL_CONNECTOR_BASE_URL=http://connector.arcanada.one:3900
MODEL_CONNECTOR_DEFAULT_MODEL=anthropic/claude-haiku-4-5

# ── Scrutator (Knowledge & LTM, Tailscale) — wired in ARCA-0008 ──────
SCRUTATOR_BASE_URL=http://arcana-db:8310
SCRUTATOR_LTM_NAMESPACE=assistant-ltm-pavel

# ── Ops Bot (event ingestion + monitoring) — wired in ARCA-0007 ──────
OPSBOT_BASE_URL=https://ops.arcanada.one
OPSBOT_API_KEY=CHANGE_ME

# ── Proactive briefings (timezone Istanbul, set in ARCA-0010) ────────
BRIEFING_TIMEZONE=Europe/Istanbul
BRIEFING_MORNING_TIME=08:00
BRIEFING_EVENING_TIME=21:00
