{
  "name": "arcanada-assistant",
  "version": "0.1.0",
  "private": true,
  "description": "Arcanada Assistant — единая точка входа в экосистему Arcanada (Telegram + AI orchestrator)",
  "license": "MIT",
  "author": "Pavel Valentov <pavel@aether-media.com>",
  "homepage": "https://assistant.arcanada.one",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Arcanada-one/arcanada-assistant.git"
  },
  "engines": {
    "node": ">=24.0.0",
    "pnpm": ">=10.0.0"
  },
  "packageManager": "pnpm@10.30.3",
  "scripts": {
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "test:coverage": "pnpm -r test:coverage",
    "lint": "pnpm -r lint",
    "lint:fix": "pnpm -r lint:fix",
    "format": "prettier --write \"**/*.{ts,js,json,md,yml,yaml}\"",
    "format:check": "prettier --check \"**/*.{ts,js,json,md,yml,yaml}\"",
    "audit:prod": "pnpm audit --prod --audit-level=high",
    "typecheck": "pnpm -r typecheck"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^26.0.1",
    "@typescript-eslint/eslint-plugin": "^8.62.0",
    "@typescript-eslint/parser": "^8.62.0",
    "@vitest/coverage-v8": "^4.1.9",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.31.0",
    "eslint-plugin-security": "^4.0.1",
    "globals": "^17.7.0",
    "prettier": "^3.9.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.0",
    "vitest": "^4.1.9"
  },
  "pnpm": {
    "overrides": {
      "fastify": "^5.8.5",
      "fast-uri": "^3.1.2"
    }
  },
  "arcanada": {
    "current_aal": "L1",
    "target_aal": "L4",
    "aal_roadmap": [
      "L1: ARCA-0006 (this) — scaffold + Docker + CI/CD",
      "L2: ARCA-0007/0008 — structured logs (pino), trace_id, Langfuse integration",
      "L3: ARCA-0009 — heartbeat to Ops Bot, output schema validation, exception hierarchy",
      "L4: ARCA-0010..0012 — cost circuit breakers, fallback chain, self-heal events"
    ]
  }
}
