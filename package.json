{
  "name": "arcanada-assistant",
  "version": "0.1.0",
  "private": true,
  "description": "Arcanada Assistant \u2014 \u0435\u0434\u0438\u043d\u0430\u044f \u0442\u043e\u0447\u043a\u0430 \u0432\u0445\u043e\u0434\u0430 \u0432 \u044d\u043a\u043e\u0441\u0438\u0441\u0442\u0435\u043c\u0443 Arcanada (Telegram + AI orchestrator)",
  "license": "MIT",
  "author": "Pavel Valentov <pavel@aether-media.com>",
  "homepage": "https://assistant.arcanada.one",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Arcanada-one/arcanada-assistant.git"
  },
  "engines": {
    "node": ">=24.0.0",
    "pnpm": ">=10.0.0"
  },
  "packageManager": "pnpm@10.30.3",
  "scripts": {
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "test:coverage": "pnpm -r test:coverage",
    "lint": "pnpm -r lint",
    "lint:fix": "pnpm -r lint:fix",
    "format": "prettier --write \"**/*.{ts,js,json,md,yml,yaml}\"",
    "format:check": "prettier --check \"**/*.{ts,js,json,md,yml,yaml}\"",
    "audit:prod": "pnpm audit --prod --audit-level=high",
    "typecheck": "pnpm -r typecheck"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^26.1.1",
    "@typescript-eslint/eslint-plugin": "^8.64.0",
    "@typescript-eslint/parser": "^8.64.0",
    "@vitest/coverage-v8": "^4.1.10",
    "eslint": "^10.7.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.31.0",
    "eslint-plugin-security": "^4.0.1",
    "globals": "^17.7.0",
    "prettier": "^3.9.5",
    "typescript": "^7.0.2",
    "typescript-eslint": "^8.64.0",
    "vitest": "^4.1.10"
  },
  "pnpm": {
    "overrides": {
      "fastify": "^5.8.5",
      "fast-uri": "^3.1.2",
      "hono": ">=4.12.25"
    }
  },
  "arcanada": {
    "current_aal": "L1",
    "target_aal": "L4",
    "aal_roadmap": [
      "L1: ARCA-0006 (this) \u2014 scaffold + Docker + CI/CD",
      "L2: ARCA-0007/0008 \u2014 structured logs (pino), trace_id, Langfuse integration",
      "L3: ARCA-0009 \u2014 heartbeat to Ops Bot, output schema validation, exception hierarchy",
      "L4: ARCA-0010..0012 \u2014 cost circuit breakers, fallback chain, self-heal events"
    ]
  }
}
